# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Environment secrets (never commit)
.env
.env.local

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Capacitor native builds (artifacts/skinscreen/mobile/capacitor)
artifacts/*/mobile/capacitor/node_modules/
artifacts/*/mobile/capacitor/ios/App/Pods/
artifacts/*/mobile/capacitor/ios/App/Podfile.lock
artifacts/*/mobile/capacitor/ios/DerivedData/
artifacts/*/mobile/capacitor/android/.gradle/
artifacts/*/mobile/capacitor/android/build/
artifacts/*/mobile/capacitor/android/app/build/
artifacts/*/mobile/capacitor/android/local.properties
