# Supabase (replace with your values)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# JWT för API: verifiering sker via JWKS (${SUPABASE_URL}/auth/v1/.well-known/jwks.json).
# SUPABASE_JWT_SECRET (HS256) behövs inte längre för Bearer-token mot detta API.

PORT=4000
NODE_ENV=development

# Optional: sätt true endast vid lokal test mot http:// utan HTTPS (annars utelämnad)
# SESSION_COOKIE_INSECURE=true
