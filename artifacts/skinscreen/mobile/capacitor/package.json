{
  "name": "chimiq-mobile",
  "version": "1.0.1",
  "private": true,
  "description": "Capacitor native shell for Chimiq (iOS + Android). NOT a pnpm workspace member — keeps @capacitor/* out of the web bundle.",
  "scripts": {
    "sync": "cap sync && bash scripts/configure-native-post-add.sh",
    "sync:ios": "cap sync ios && bash scripts/configure-native-post-add.sh",
    "sync:android": "cap sync android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "build:android": "cd android && ./gradlew bundleRelease",
    "assets": "capacitor-assets generate --iconBackgroundColor '#F5F1EB' --iconBackgroundColorDark '#F5F1EB' --splashBackgroundColor '#F5F1EB' --splashBackgroundColorDark '#F5F1EB' --assetPath resources"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.5",
    "@capacitor/camera": "^6.1.2",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@capacitor-mlkit/barcode-scanning": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1"
  }
}
