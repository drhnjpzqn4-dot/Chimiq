{
  "outputDirectory": "dist/public",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/skinscreen run build",
  "installCommand": "cd ../.. && pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-58f9.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
